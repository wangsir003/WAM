{
  "name": "wam",
  "version": "1.0.0",
  "description": "Windows Android-project Manager - 专为 Android 开发者设计的桌面应用",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "setup-adb": "node setup-adb.js",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5888 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "build:win": "vite build && electron-builder --win --config",
    "build:portable": "vite build && electron-builder --win portable --config"
  },
  "keywords": [
    "electron",
    "vue",
    "android",
    "adb",
    "developer-tools"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@ant-design/icons-vue": "^7.0.1",
    "ant-design-vue": "^4.1.0",
    "pinia": "^2.1.7",
    "vue": "^3.4.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "png-to-ico": "^3.0.1",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.wam.app",
    "productName": "WAM",
    "directories": {
      "output": "pkg",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "!**/*.map",
      "!**/node_modules/**",
      "!src/**",
      "!.vscode/**",
      "!*.md"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      },
      {
        "from": "resources/platform-tools",
        "to": "platform-tools",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    }
  }
}
